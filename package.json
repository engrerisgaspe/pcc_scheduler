{
  "name": "senior-high-scheduling-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @school-scheduler/web",
    "dev:api": "npm run dev --workspace @school-scheduler/api",
    "build": "npm run build --workspace @school-scheduler/shared && npm run build --workspace @school-scheduler/api && npm run build --workspace @school-scheduler/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:seed": "npm run seed --workspace @school-scheduler/api",
    "db:terms": "tsx prisma/backfill-school-terms.ts",
    "db:planning": "tsx prisma/bootstrap-planning-data.ts",
    "db:loading-limits": "tsx prisma/import-loading-limits.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "typescript": "^5.8.3"
  }
}
